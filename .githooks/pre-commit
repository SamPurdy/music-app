#!/bin/bash
# pre-commit hook: warns if docs/HANDOFF.md has not been updated in this commit
# Install: git config core.hooksPath .githooks

HANDOFF="docs/HANDOFF.md"
STAGED=$(git diff --cached --name-only)

# Check if any src/ files are being committed
SRC_CHANGED=$(echo "$STAGED" | grep -c "^src/")

if [ "$SRC_CHANGED" -gt 0 ]; then
  # src/ files are staged — HANDOFF.md should also be staged
  HANDOFF_STAGED=$(echo "$STAGED" | grep -c "^docs/HANDOFF.md")

  if [ "$HANDOFF_STAGED" -eq 0 ]; then
    echo ""
    echo "⚠️  WARNING: You are committing src/ changes but docs/HANDOFF.md has NOT been updated."
    echo ""
    echo "   The local model should update HANDOFF.md at the end of each session."
    echo "   This helps the next session start with full context."
    echo ""
    echo "   To skip this warning and commit anyway:"
    echo "   git commit --no-verify"
    echo ""
    echo "   To update HANDOFF.md first:"
    echo "   Edit docs/HANDOFF.md, then: git add docs/HANDOFF.md && git commit"
    echo ""
    # Exit 1 blocks the commit; exit 0 allows it with just a warning
    # Using exit 0 (warn-only) so it never hard-blocks the user
    exit 0
  fi
fi

exit 0
